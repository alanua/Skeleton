{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.telegram_approval_buttons.schema.json",
  "$defs": {
    "callback": {
      "type": "object",
      "required": ["schema", "action", "repo", "pr_number", "head_sha"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "skeleton.telegram_approval_buttons.callback.v1"
        },
        "action": {
          "type": "string",
          "enum": ["approve", "reject", "details", "open_pr"]
        },
        "repo": {
          "type": "string",
          "enum": ["alanua/Skeleton"]
        },
        "pr_number": {
          "type": "integer",
          "minimum": 1
        },
        "head_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "button": {
      "type": "object",
      "required": ["action", "label", "callback_payload"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": ["approve", "reject", "details", "open_pr"]
        },
        "label": {
          "type": "string"
        },
        "callback_payload": {
          "$ref": "#/$defs/callback"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 512
        }
      }
    }
  },
  "type": "object",
  "required": [
    "schema",
    "kind",
    "repo",
    "pr_number",
    "head_sha",
    "pr_url",
    "changed_files",
    "changed_files_total",
    "changed_files_truncated",
    "test_summary",
    "risk_summary",
    "text",
    "buttons"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "skeleton.telegram_approval_buttons.card.v1"
    },
    "kind": {
      "type": "string",
      "const": "completed_pr_review"
    },
    "repo": {
      "type": "string",
      "enum": ["alanua/Skeleton"]
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "pr_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 512
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "maxLength": 180,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\\\).+$"
      }
    },
    "changed_files_total": {
      "type": "integer",
      "minimum": 1
    },
    "changed_files_truncated": {
      "type": "boolean"
    },
    "test_summary": {
      "type": "string",
      "maxLength": 240
    },
    "risk_summary": {
      "type": "string",
      "maxLength": 240
    },
    "text": {
      "type": "string"
    },
    "buttons": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/button"
      }
    }
  }
}
