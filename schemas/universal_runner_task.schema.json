{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/universal_runner_task.schema.json",
  "title": "Universal Runner Task Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task_id",
    "idempotency_key",
    "action",
    "executor_type",
    "capability",
    "risk_class",
    "target",
    "repo",
    "branch",
    "task",
    "allowed_files_or_resources",
    "forbidden_actions",
    "validation",
    "expected_output",
    "privacy_boundary",
    "timeout_seconds",
    "approval_requirement",
    "private_payload_ref"
  ],
  "properties": {
    "schema": {
      "const": "skeleton.universal_runner_task.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{0,160}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{0,160}$"
    },
    "action": {
      "enum": ["START", "STATUS", "CONTINUE", "CANCEL"]
    },
    "executor_type": {
      "enum": [
        "codex_branch_task",
        "hermes_private_task",
        "local_module_task",
        "runtime_maintenance_task",
        "read_only_probe"
      ]
    },
    "capability": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{0,160}$"
    },
    "risk_class": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{0,160}$"
    },
    "branch": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{0,160}$"
    },
    "task": {
      "type": "string"
    },
    "allowed_files_or_resources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "validation": {
      "type": "object"
    },
    "expected_output": {
      "type": "string"
    },
    "privacy_boundary": {
      "type": "string",
      "minLength": 1
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "approval_requirement": {
      "enum": ["none", "explicit", "protected", "high_risk"]
    },
    "private_payload_ref": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{2,200}$"
    },
    "approval_evidence": {
      "type": "object"
    }
  }
}
