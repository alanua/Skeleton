{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.skeleton.local/private_memory_reconciliation_report.schema.json",
  "title": "Skeleton Private Memory Reconciliation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_id",
    "generated_at",
    "source_inventory_ref",
    "source_inventory_hash",
    "extraction_manifest_ref",
    "extraction_manifest_hash",
    "target_canonical_revision",
    "aggregate_counts",
    "records",
    "report_hash"
  ],
  "properties": {
    "schema": {"const": "skeleton.private_memory_reconciliation_report.v1"},
    "report_id": {"$ref": "#/$defs/safe_ref"},
    "generated_at": {"$ref": "#/$defs/date_time"},
    "source_inventory_ref": {"$ref": "#/$defs/safe_ref"},
    "source_inventory_hash": {"$ref": "#/$defs/hash"},
    "extraction_manifest_ref": {"$ref": "#/$defs/safe_ref"},
    "extraction_manifest_hash": {"$ref": "#/$defs/hash"},
    "target_canonical_revision": {"type": "integer", "minimum": 0},
    "aggregate_counts": {"$ref": "#/$defs/aggregate_counts"},
    "records": {
      "type": "array",
      "items": {"$ref": "#/$defs/record"}
    },
    "report_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "safe_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "not": {"pattern": "://|/|\\\\|\\.\\.|\\s"}
    },
    "date_time": {"type": "string", "format": "date-time"},
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "aggregate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["add", "update", "tombstone", "conflict", "unchanged", "total"],
      "properties": {
        "add": {"type": "integer", "minimum": 0},
        "update": {"type": "integer", "minimum": 0},
        "tombstone": {"type": "integer", "minimum": 0},
        "conflict": {"type": "integer", "minimum": 0},
        "unchanged": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      }
    },
    "operator_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_ref", "decision_state", "required_by_ref"],
      "properties": {
        "decision_ref": {"$ref": "#/$defs/safe_ref"},
        "decision_state": {"enum": ["pending_approval", "approved", "rejected"]},
        "required_by_ref": {"$ref": "#/$defs/safe_ref"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_record_ref",
        "operation",
        "current_hash",
        "proposed_hash",
        "reason_codes",
        "unresolved_operator_decision"
      ],
      "properties": {
        "stable_record_ref": {"$ref": "#/$defs/safe_ref"},
        "operation": {"enum": ["add", "update", "tombstone", "conflict", "unchanged"]},
        "current_hash": {"anyOf": [{"$ref": "#/$defs/hash"}, {"type": "null"}]},
        "proposed_hash": {"anyOf": [{"$ref": "#/$defs/hash"}, {"type": "null"}]},
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safe_ref"}
        },
        "unresolved_operator_decision": {
          "anyOf": [
            {"$ref": "#/$defs/operator_decision"},
            {"type": "null"}
          ]
        }
      }
    }
  }
}
