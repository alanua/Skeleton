{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.runner_bridge.schema.json",
  "type": "object",
  "required": ["repo", "base_ref", "task_title", "task_body", "allowed_files", "protected_files", "validation_commands", "approval_marker"],
  "additionalProperties": false,
  "properties": {
    "repo": {"type": "string", "minLength": 1},
    "base_ref": {"type": "string", "minLength": 1},
    "task_title": {"type": "string", "minLength": 1},
    "task_body": {"type": "string", "minLength": 1},
    "allowed_files": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "protected_files": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "validation_commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "approval_marker": {"type": "string", "minLength": 1}
  }
}
