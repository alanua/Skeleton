{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.memory_bootstrap.response.schema.json",
  "title": "Memory Bootstrap Response",
  "type": "object",
  "required": ["schema", "project_id", "dataset_id", "current_canonical_revision", "canonical_exact_records", "selected_context"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "skeleton.memory_bootstrap.response.v1"},
    "project_id": {"type": "string"},
    "dataset_id": {"type": "string"},
    "current_canonical_revision": {"type": "integer", "minimum": 0},
    "canonical_exact_records": {"type": "object"},
    "selected_context": {
      "type": "object",
      "required": ["semantic_layer", "semantic_reason", "graph_layer", "graph_reason"],
      "additionalProperties": false,
      "properties": {
        "semantic_layer": {"type": ["object", "null"]},
        "semantic_reason": {"type": "string"},
        "graph_layer": {"type": ["object", "null"]},
        "graph_reason": {"type": "string"}
      }
    }
  }
}
