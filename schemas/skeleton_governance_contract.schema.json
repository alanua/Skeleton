{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.governance_contract.schema.json",
  "type": "object",
  "required": [
    "schema",
    "version",
    "authority_ladder",
    "memory_boundary",
    "role_manifest_ref",
    "evidence_packet_ref",
    "task_template_ref",
    "gate_fixture_refs",
    "non_goals"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "skeleton.governance_contract.v1"
    },
    "version": {
      "const": 1
    },
    "authority_ladder": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["rank", "source", "canon_role"],
        "additionalProperties": false,
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "canon_role": {
            "type": "string",
            "enum": [
              "current_instruction",
              "canon",
              "identity",
              "handoff_not_canon",
              "read_only_mirror",
              "weak_cache"
            ]
          }
        }
      }
    },
    "memory_boundary": {
      "type": "object",
      "required": ["canon_status", "allowed", "forbidden", "promotion_rule"],
      "additionalProperties": false,
      "properties": {
        "canon_status": {
          "type": "string",
          "const": "memory_is_not_canon"
        },
        "allowed": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "promotion_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "role_manifest_ref": {
      "type": "string",
      "pattern": "^schemas/skeleton_role_manifest\\.schema\\.json$"
    },
    "evidence_packet_ref": {
      "type": "string",
      "pattern": "^schemas/skeleton_evidence_packet\\.schema\\.json$"
    },
    "task_template_ref": {
      "type": "string",
      "pattern": "^schemas/skeleton_task_template\\.schema\\.json$"
    },
    "gate_fixture_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^fixtures/governance/.+\\.json$"
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["runtime", "deploy", "secrets", "server", "merge", "publish"]
      }
    }
  }
}
