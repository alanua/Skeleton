{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.hermes_memory_result.schema.json",
  "title": "Hermes Memory Result",
  "type": "object",
  "required": [
    "schema",
    "namespace",
    "project_id",
    "capability",
    "authoritative",
    "canonical_write_performed",
    "write_gate",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "skeleton.hermes_memory.result.v1"},
    "namespace": {"$ref": "#/$defs/namespace"},
    "project_id": {"$ref": "#/$defs/namespace"},
    "capability": {"type": "string"},
    "authoritative": {"type": "boolean"},
    "canonical_write_performed": {"const": false},
    "write_gate": {
      "type": "object",
      "required": ["outcome", "reason"],
      "additionalProperties": true,
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["APPROVED_FOR_OPERATOR", "REVIEW_REQUIRED", "BLOCKED", "DUPLICATE_EXISTING"]
        },
        "reason": {"type": "string"}
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "namespace": {
      "type": "string",
      "enum": ["aufmass", "bauclock", "skeleton", "home_automation", "legal_private"]
    }
  }
}
