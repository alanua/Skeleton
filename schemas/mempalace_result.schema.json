{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.mempalace_result.schema.json",
  "title": "MemPalace Synthetic Search Result",
  "type": "object",
  "required": [
    "schema",
    "authoritative",
    "namespace",
    "project_id",
    "result_refs",
    "source_attribution",
    "score",
    "indexed_canonical_revision",
    "current_canonical_revision",
    "source_snapshot_id",
    "indexed_at",
    "stale",
    "bounded_text"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "skeleton.mempalace_result.v1"},
    "authoritative": {"const": false},
    "namespace": {"const": "skeleton"},
    "project_id": {"const": "mempalace_synthetic"},
    "result_refs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/safe_token"}
    },
    "source_attribution": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/source_attribution"}
    },
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "indexed_canonical_revision": {"type": "integer", "minimum": 1},
    "current_canonical_revision": {"type": "integer", "minimum": 1},
    "source_snapshot_id": {"$ref": "#/$defs/safe_token"},
    "indexed_at": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "stale": {"type": "boolean"},
    "bounded_text": {"type": "string", "minLength": 1, "maxLength": 180}
  },
  "$defs": {
    "safe_token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "source_attribution": {
      "type": "object",
      "required": ["source_ref", "kind", "evidence_hash"],
      "additionalProperties": false,
      "properties": {
        "source_ref": {"$ref": "#/$defs/safe_token"},
        "kind": {"$ref": "#/$defs/safe_token"},
        "evidence_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    }
  }
}
