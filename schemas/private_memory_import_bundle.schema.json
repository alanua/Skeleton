{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.skeleton.local/private_memory_import_bundle.schema.json",
  "title": "Skeleton Private Memory Import Bundle",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "bundle_id", "privacy_class", "operator_approved", "record_count", "records"],
  "properties": {
    "schema": {"const": "skeleton.private_memory_import_bundle.v1"},
    "bundle_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "privacy_class": {"const": "LOCAL_PRIVATE"},
    "operator_approved": {"const": true},
    "record_count": {"type": "integer", "minimum": 0, "maximum": 10000},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["namespace", "fact_id", "actor", "reason", "approval", "value"],
        "properties": {
          "namespace": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
          "fact_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
          "actor": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
          "reason": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
          "approval": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
          "value": true
        }
      }
    }
  }
}
