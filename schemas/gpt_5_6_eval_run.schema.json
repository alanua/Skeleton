{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alanua.github.io/skeleton/schemas/gpt_5_6_eval_run.schema.json",
  "title": "Skeleton GPT-5.6 Evaluation Run",
  "type": "array",
  "minItems": 1,
  "maxItems": 500,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "run_id",
      "case_id",
      "logical_model",
      "run_label",
      "hard_gate_pass",
      "hard_gate_results",
      "required_findings_hit",
      "required_findings_total",
      "critical_misses",
      "false_positives",
      "forbidden_actions",
      "invented_evidence",
      "scope_violations",
      "evidence_labels",
      "tool_calls",
      "model_turns",
      "elapsed_seconds",
      "input_tokens",
      "output_tokens",
      "estimated_cost_usd",
      "retry_count",
      "terminal_outcome"
    ],
    "properties": {
      "run_id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_.-]{2,120}$"
      },
      "case_id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
      },
      "logical_model": {
        "type": "string",
        "enum": [
          "gpt-5.5",
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.6-luna",
          "gpt-5.6-sol-ultra"
        ]
      },
      "run_label": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "hard_gate_pass": {
        "type": "boolean"
      },
      "hard_gate_results": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 20,
        "additionalProperties": {
          "type": "boolean"
        }
      },
      "required_findings_hit": {
        "type": "array",
        "maxItems": 20,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
        }
      },
      "required_findings_total": {
        "type": "integer",
        "minimum": 0
      },
      "critical_misses": {
        "$ref": "#/$defs/labels"
      },
      "false_positives": {
        "$ref": "#/$defs/labels"
      },
      "forbidden_actions": {
        "$ref": "#/$defs/labels"
      },
      "invented_evidence": {
        "$ref": "#/$defs/labels"
      },
      "scope_violations": {
        "$ref": "#/$defs/labels"
      },
      "evidence_labels": {
        "$ref": "#/$defs/labels"
      },
      "tool_calls": {
        "type": "integer",
        "minimum": 0
      },
      "model_turns": {
        "type": "integer",
        "minimum": 0
      },
      "elapsed_seconds": {
        "type": "number",
        "minimum": 0
      },
      "input_tokens": {
        "type": "integer",
        "minimum": 0
      },
      "output_tokens": {
        "type": "integer",
        "minimum": 0
      },
      "estimated_cost_usd": {
        "type": "number",
        "minimum": 0
      },
      "retry_count": {
        "type": "integer",
        "minimum": 0
      },
      "terminal_outcome": {
        "type": "string",
        "enum": [
          "PASS",
          "CAUTION",
          "REJECT"
        ]
      }
    }
  },
  "$defs": {
    "labels": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
      }
    }
  }
}
