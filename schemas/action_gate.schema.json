{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.action_gate.schema.json",
  "type": "object",
  "required": [
    "action_type",
    "repo",
    "pr_number",
    "expected_head_sha",
    "expected_files",
    "user_approved"
  ],
  "additionalProperties": false,
  "properties": {
    "action_type": {
      "type": "string",
      "enum": ["merge_pull_request"]
    },
    "repo": {
      "type": "string",
      "enum": ["alanua/Skeleton"]
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "expected_head_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "expected_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\\\).+$"
      }
    },
    "user_approved": {
      "type": "boolean",
      "const": true
    }
  }
}
