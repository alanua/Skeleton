{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.graph_query.schema.json",
  "title": "Graphify Memory Gateway Query",
  "type": "object",
  "required": ["schema", "namespace", "project_id", "query", "limit"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "skeleton.graphify.query.v1"},
    "namespace": {"const": "skeleton"},
    "project_id": {"const": "graphify_synthetic"},
    "query": {
      "type": "string",
      "enum": [
        "module_relationship",
        "schema_relationship",
        "test_relationship",
        "dependency_relationship",
        "provenance_relationship"
      ]
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "include_stale": {"type": "boolean"}
  }
}
