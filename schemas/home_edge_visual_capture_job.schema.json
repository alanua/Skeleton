{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alanua/Skeleton/schemas/home_edge_visual_capture_job.schema.json",
  "title": "Home Edge Visual Capture Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "action_id",
    "task_ref",
    "provider",
    "url",
    "requested_time_seconds"
  ],
  "properties": {
    "schema": {
      "const": "skeleton.home_edge.visual_capture.job.v1"
    },
    "action_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "task_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "provider": {
      "const": "youtube"
    },
    "url": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "requested_time_seconds": {
      "type": "number",
      "minimum": 0,
      "maximum": 86400
    },
    "offsets_seconds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "integer",
        "minimum": -10,
        "maximum": 10
      }
    },
    "capture_mode": {
      "enum": [
        "background",
        "visible_kiosk"
      ]
    },
    "human_review_required": {
      "type": "boolean"
    }
  },
  "not": {
    "anyOf": [
      {"required": ["command"]},
      {"required": ["selector"]},
      {"required": ["executable_path"]},
      {"required": ["output_path"]},
      {"required": ["artifact_root"]},
      {"required": ["profile_path"]},
      {"required": ["host"]},
      {"required": ["user"]},
      {"required": ["port"]}
    ]
  }
}
