{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.memory_bootstrap_request.schema.json",
  "title": "Memory Bootstrap Request",
  "type": "object",
  "required": ["schema", "mandatory", "private_root", "scope", "canonical_refs"],
  "additionalProperties": true,
  "properties": {
    "schema": {"const": "skeleton.memory_bootstrap.request.v1"},
    "mandatory": {"const": true},
    "private_root": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "required": ["project_id", "dataset_id", "repository", "branch", "task_transition_hash"],
      "additionalProperties": false,
      "properties": {
        "project_id": {"type": "string"},
        "dataset_id": {"type": "string"},
        "repository": {"type": "string"},
        "branch": {"type": "string"},
        "task_transition_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "canonical_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "query": {"type": "string"},
    "repository_root": {"type": "string"},
    "worktree_root": {"type": "string"}
  }
}
