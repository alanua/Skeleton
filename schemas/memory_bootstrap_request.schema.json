{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.memory_bootstrap.request.schema.json",
  "title": "Memory Bootstrap Request",
  "type": "object",
  "required": ["schema", "project_id", "dataset_id", "query", "canonical_keys", "current_canonical_revision"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "skeleton.memory_bootstrap.request.v1"},
    "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "dataset_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "query": {"type": "string", "minLength": 1, "maxLength": 4096},
    "canonical_keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {"type": "string", "minLength": 1, "maxLength": 128}
    },
    "current_canonical_revision": {"type": "integer", "minimum": 0}
  }
}
