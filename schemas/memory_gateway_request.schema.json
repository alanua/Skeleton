{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.memory_gateway_request.schema.json",
  "title": "Memory Gateway Request",
  "type": "object",
  "required": ["schema", "namespace", "command", "payload"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "skeleton.memory_gateway.request.v1"},
    "namespace": {"$ref": "#/$defs/namespace"},
    "command": {
      "type": "string",
      "pattern": "^(aufmass|bauclock|skeleton|home_automation|legal_private)\\.(memory\\.lookup_exact|memory\\.search_semantic|memory\\.get_conflicts|memory\\.get_override_history|memory\\.get_audit_log|memory\\.get_index_freshness|memory\\.prepare_canonical_manifest|graph\\.query_code|graph\\.get_index_freshness|memory\\.propose_patch)$"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "namespace": {
      "type": "string",
      "enum": ["aufmass", "bauclock", "skeleton", "home_automation", "legal_private"]
    }
  }
}
