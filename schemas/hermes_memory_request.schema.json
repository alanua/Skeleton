{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.hermes_memory_request.schema.json",
  "type": "object",
  "required": [
    "schema",
    "namespace",
    "project_id",
    "operation",
    "parameters"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "skeleton.hermes_memory_request.v1"
    },
    "namespace": {
      "type": "string",
      "enum": ["aufmass", "bauclock", "skeleton", "home_automation", "legal_private"]
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "operation": {
      "type": "string",
      "enum": [
        "memory.lookup_exact",
        "memory.search_semantic",
        "memory.get_index_freshness",
        "graph.query_code",
        "graph.get_index_freshness",
        "memory.propose_patch"
      ]
    },
    "parameters": {
      "type": "object"
    }
  }
}
