{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alanua/Skeleton/schemas/runner_task.schema.json",
  "title": "Skeleton Runner Task Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repo",
    "branch",
    "base_sha",
    "task_kind",
    "payload",
    "requested_capabilities",
    "allowed_files",
    "forbidden_actions",
    "validation_commands",
    "validation_timeout_seconds",
    "expected_output",
    "privacy_boundary",
    "approval_reference",
    "idempotency_key"
  ],
  "properties": {
    "schema": {
      "const": "skeleton.runner_task.v1"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9_.-]{0,99})/[A-Za-z0-9](?:[A-Za-z0-9_.-]{0,99})$"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "base_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "task_kind": {
      "enum": [
        "code_edit",
        "repository_maintenance",
        "private_memory",
        "diagnostic",
        "loop_control",
        "publish"
      ]
    },
    "payload": {
      "type": "object",
      "maxProperties": 256,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
      }
    },
    "requested_capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "repository_read",
          "repository_write_allowlisted",
          "test_execution",
          "subprocess_isolated",
          "memory_gateway_read",
          "memory_gateway_write",
          "diagnostic_read",
          "repository_maintenance",
          "loop_control",
          "publish_pull_request"
        ]
      }
    },
    "allowed_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\)[A-Za-z0-9._-][A-Za-z0-9._/@+\\-]*$"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "array",
        "minItems": 1,
        "maxItems": 64,
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    },
    "validation_timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "expected_output": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "privacy_boundary": {
      "enum": [
        "PUBLIC_SAFE_REPOSITORY_ONLY",
        "PUBLIC_SAFE_AGGREGATE_ONLY",
        "LOCAL_PRIVATE",
        "PRIVATE_LOCAL"
      ]
    },
    "approval_reference": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    }
  }
}
