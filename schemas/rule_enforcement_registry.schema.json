{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.rule_enforcement_registry.schema.json",
  "title": "Skeleton Rule Enforcement Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "status",
    "program",
    "stage",
    "boundary",
    "issue_refs",
    "source_coverage",
    "rules",
    "next_stages"
  ],
  "properties": {
    "schema": {
      "const": "skeleton.rule_enforcement_registry.v1"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "const": "stage0_inventory_only"
    },
    "program": {
      "const": "Skeleton Rules Rebuild"
    },
    "stage": {
      "const": "stage0_foundation"
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_behavior_changed",
        "merge_enabled",
        "canon_promotion_enabled",
        "skeleton_jeeves_boundary"
      ],
      "properties": {
        "runtime_behavior_changed": {
          "const": false
        },
        "merge_enabled": {
          "const": false
        },
        "canon_promotion_enabled": {
          "const": false
        },
        "skeleton_jeeves_boundary": {
          "const": "preserved"
        }
      }
    },
    "issue_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^#[0-9]+$"
      },
      "uniqueItems": true,
      "contains": {
        "const": "#1088"
      }
    },
    "source_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceCoverage"
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "next_stages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage",
          "goal"
        ],
        "properties": {
          "stage": {
            "type": "string",
            "pattern": "^stage[1-3]_[a-z0-9_]+$"
          },
          "goal": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "sourceCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "classification",
        "notes"
      ],
      "properties": {
        "source_file": {
          "$ref": "#/$defs/repositoryPath"
        },
        "classification": {
          "enum": [
            "covered",
            "advisory",
            "planned",
            "duplicated",
            "contradictory",
            "dead",
            "needs_review"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "source_file",
        "source_locator",
        "owner_component",
        "lifecycle",
        "enforcement",
        "gate_entrypoint",
        "reason_tokens",
        "test_evidence",
        "protected_actions",
        "approval_scope",
        "public_private_boundary",
        "supersedes",
        "superseded_by",
        "notes"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_file": {
          "$ref": "#/$defs/repositoryPath"
        },
        "source_locator": {
          "type": "string",
          "minLength": 1
        },
        "owner_component": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle": {
          "enum": [
            "active",
            "advisory",
            "planned",
            "deprecated",
            "superseded",
            "needs_review"
          ]
        },
        "enforcement": {
          "enum": [
            "runtime_gate",
            "preflight_gate",
            "schema_validation",
            "route_validation",
            "test_only",
            "documentation_only",
            "none"
          ]
        },
        "gate_entrypoint": {
          "type": "string"
        },
        "reason_tokens": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true
        },
        "test_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "protected_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true
        },
        "approval_scope": {
          "enum": [
            "none",
            "exact_pr_head_and_files",
            "exact_task_id",
            "exact_route_and_target",
            "exact_project_route",
            "exact_provider_tier_and_budget",
            "exact_memory_classification",
            "exact_executor_lane",
            "exact_queue_issue",
            "exact_private_boundary"
          ]
        },
        "public_private_boundary": {
          "enum": [
            "public_only",
            "private_only",
            "public_summary_private_detail",
            "no_private_data",
            "not_applicable"
          ]
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "superseded_by": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "repositoryPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+(/[A-Za-z0-9_.-]+)*$",
      "not": {
        "pattern": "(^/|\\.\\.|\\\\)"
      }
    }
  }
}
