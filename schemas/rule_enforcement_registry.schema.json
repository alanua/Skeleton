{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skeleton.rule_enforcement_registry.schema.json",
  "title": "Skeleton Rule Enforcement Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "status",
    "program",
    "stage",
    "boundary",
    "issue_refs",
    "source_coverage",
    "rules",
    "next_stages"
  ],
  "properties": {
    "schema": {"const": "skeleton.rule_enforcement_registry.v1"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"const": "stage0_inventory_only"},
    "program": {"const": "Skeleton Rules Rebuild"},
    "stage": {"const": "stage0_current_main"},
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_behavior_changed",
        "merge_enabled",
        "canon_promotion_enabled",
        "private_data_allowed",
        "skeleton_jeeves_boundary"
      ],
      "properties": {
        "runtime_behavior_changed": {"const": false},
        "merge_enabled": {"const": false},
        "canon_promotion_enabled": {"const": false},
        "private_data_allowed": {"const": false},
        "skeleton_jeeves_boundary": {"const": "preserved"}
      }
    },
    "issue_refs": {
      "type": "array",
      "items": {"type": "string", "pattern": "^#[0-9]+$"},
      "uniqueItems": true,
      "contains": {"const": "#1088"},
      "minItems": 1
    },
    "source_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/sourceCoverage"}
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/rule"}
    },
    "next_stages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "goal"],
        "properties": {
          "stage": {"type": "string", "pattern": "^stage[1-3]_[a-z0-9_]+$"},
          "goal": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "repoPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+(/[A-Za-z0-9_.-]+)*$",
      "not": {"pattern": "(^/|\\.\\.|\\\\)"}
    },
    "sourceCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_file", "classification", "notes"],
      "properties": {
        "source_file": {"$ref": "#/$defs/repoPath"},
        "classification": {
          "enum": ["covered", "advisory", "planned", "duplicated", "contradictory", "dead", "needs_review"]
        },
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "source_type",
        "source_ref",
        "source_locator",
        "owner_component",
        "scope",
        "lifecycle",
        "policy_severity",
        "enforcement_state",
        "gate_entrypoint",
        "reason_tokens",
        "approval_binding",
        "test_evidence",
        "privacy_boundary",
        "supersedes",
        "superseded_by",
        "notes"
      ],
      "properties": {
        "rule_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "title": {"type": "string", "minLength": 1},
        "source_type": {"enum": ["file", "issue"]},
        "source_ref": {
          "type": "string",
          "pattern": "^(#[0-9]+|[A-Za-z0-9_.-]+(/[A-Za-z0-9_.-]+)*)$",
          "not": {"pattern": "(^/|\\.\\.|\\\\)"}
        },
        "source_locator": {"type": "string", "minLength": 1},
        "owner_component": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$"},
        "lifecycle": {"enum": ["active", "advisory", "planned", "deprecated", "superseded", "needs_review"]},
        "policy_severity": {"enum": ["block", "require_approval", "rewrite", "warn", "log"]},
        "enforcement_state": {"enum": ["runtime_gate", "preflight_gate", "schema_validation", "route_validation", "test_only", "documentation_only", "none"]},
        "gate_entrypoint": {"type": "string"},
        "reason_tokens": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
          "uniqueItems": true
        },
        "approval_binding": {
          "enum": [
            "none",
            "exact_pr_head_and_files",
            "exact_task_and_base",
            "exact_route_scope_risk",
            "exact_protected_resource",
            "exact_provider_privacy_budget",
            "exact_memory_classification",
            "exact_operator_event",
            "exact_private_boundary"
          ]
        },
        "test_evidence": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "privacy_boundary": {"enum": ["public_only", "private_only", "public_summary_private_detail", "no_private_data", "not_applicable"]},
        "supersedes": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "uniqueItems": true
        },
        "superseded_by": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "uniqueItems": true
        },
        "notes": {"type": "string"}
      }
    }
  }
}
