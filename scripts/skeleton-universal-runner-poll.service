[Unit]
Description=Skeleton Universal TaskEnvelope Queue Poller
After=network.target

[Service]
Type=oneshot
User=agent
WorkingDirectory=/home/agent/agent-dev/repos/Skeleton
EnvironmentFile=-/etc/skeleton-runner.env
ExecStart=/usr/bin/python3 scripts/runner_poll_universal_tasks.py --envelopes-only
StandardOutput=journal
StandardError=journal
