# Copy this file to an uncommitted env file and replace every descriptor.
COMPOSE_PROJECT_NAME=skeleton-n8n-community
N8N_COMPOSE_PROJECT_NAME=skeleton-n8n-community

# Loopback-only editor. Use Tailscale SSH or an SSH tunnel for private access.
N8N_EDITOR_PORT=5678
N8N_HOST=127.0.0.1

# Must be an absolute, dedicated, owner-only host directory for /home/node/.n8n.
# The directory must be owned by the runtime owner and mode 700 before start.
N8N_DATA_DIR=/srv/n8n-community/data

# Must be an absolute, dedicated backup directory outside N8N_DATA_DIR.
N8N_BACKUP_DIR=/srv/n8n-community/backups

# Private descriptor only. Generate a real 32+ character value outside git.
N8N_ENCRYPTION_KEY=REPLACE_WITH_PRIVATE_32_PLUS_CHARACTER_ENCRYPTION_KEY
